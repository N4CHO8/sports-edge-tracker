# Supabase server-side access. Keep the service role key only in Vercel env vars.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required. If omitted, the app shows a configuration error instead of inventing demo data.
ODDS_API_KEY=your-the-odds-api-key
ODDS_API_SPORT_KEYS=mma_mixed_martial_arts,basketball_nba,soccer_fifa_world_cup
ODDS_API_REGIONS=us,eu
ODDS_API_MARKETS=h2h
ODDS_API_ODDS_FORMAT=decimal
ODDS_API_MAX_LOOKAHEAD_DAYS=60
ODDS_API_REQUIRE_UFC_OFFICIAL=true
ODDS_API_AUTO_MAJOR_TOURNAMENTS=true

# Optional for advanced football stats. Create it in API-Sports / API-Football.
API_SPORTS_KEY=your-api-sports-key
API_SPORTS_LAST_MATCHES=20
API_SPORTS_DETAIL_MATCHES=20
